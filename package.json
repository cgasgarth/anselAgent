{
  "name": "ansel-agent",
  "private": true,
  "scripts": {
    "bootstrap": "./scripts/install.sh",
    "agent:eval": "uv run python -c \"from server.evals.harness import main; raise SystemExit(main())\"",
    "dev": "ANSEL_FRESH_RUNTIME=1 ANSEL_SKIP_CONFIG=1 npm run ansel:build && ANSEL_FRESH_RUNTIME=1 npm run ansel:start && npm run server:start",
    "ansel:build": "./scripts/build_ansel_local.sh",
    "ansel:build:macos-bundle": "ANSEL_MACOS_BUNDLE=1 ./scripts/build_ansel_local.sh",
    "ansel:upstream-status": "python3 ./scripts/ansel_upstream.py status",
    "ansel:start": "./scripts/run_ansel_local.sh",
    "ansel:start:macos-bundle": "ANSEL_MACOS_BUNDLE=1 ./scripts/run_ansel_local.sh",
    "ansel:build-and-start": "npm run ansel:build && npm run ansel:start",
    "ansel:deps:macos": "./ansel/packaging/install-deps-macos.sh",
    "server:start": "./scripts/run_server.sh",
    "validate:agent": "./scripts/validate_agent.sh",
    "agent:smoke": "./scripts/agent_exposure_smoke.sh",
    "agent:smoke:graph-export": "./scripts/agent_graph_smoke.sh",
    "agent:smoke:multi-turn": "MULTI_TURN_ENABLED=1 EXPECTED_DELTA= EXPECTED_FINAL_EXPOSURE=1.4 EXPECTED_MIN_REFINEMENT_PASSES=2 EXPECTED_MAX_REFINEMENT_PASSES=15 ANSEL_AGENT_TEST_AUTORUN_QUIT_AFTER_MS=5000 ./scripts/agent_exposure_smoke.sh"
  }
}
